# Local override for where swarmhq should read config from.
SWARM_CONFIG_FILE=

# Keepalived VRRP auth password. Keep this only in local env files.
SWARM_VRRP_PASSWORD=replace-me

# Optional auth token for tailscale integration or future automation.
SWARM_TAILSCALE_AUTHKEY=

# Set to false to keep `swarmhq ui` from opening a browser automatically.
SWARM_UI_OPEN=true
