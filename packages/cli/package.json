{
  "name": "swarmhq",
  "version": "0.1.3",
  "type": "module",
  "description": "Docker Swarm management CLI with an embedded localhost dashboard",
  "bin": {
    "swarmhq": "dist/bin.js"
  },
  "files": [
    "dist",
    "ui-dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scoobydrew83/swarmhq.git"
  },
  "homepage": "https://github.com/scoobydrew83/swarmhq#readme",
  "bugs": {
    "url": "https://github.com/scoobydrew83/swarmhq/issues"
  },
  "keywords": [
    "docker",
    "swarm",
    "cli",
    "devops",
    "cluster",
    "keepalived",
    "ssh",
    "dashboard",
    "management"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "bundle:ui": "node ./scripts/copy-ui.mjs",
    "prepublishOnly": "npm run typecheck -w @swarmhq/core && npm run typecheck -w swarmhq"
  },
  "devDependencies": {
    "@swarmhq/core": "0.1.0",
    "tsup": "^8.5.1"
  }
}
