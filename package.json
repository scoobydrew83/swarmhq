{
  "name": "swarmhq-workspace",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "npm run build -w @swarmhq/core && npm run build -w swarmhq && npm run build -w @swarmhq/ui && npm run bundle:ui -w swarmhq",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint packages/*/src --ext .ts,.tsx",
    "lint:fix": "eslint packages/*/src --ext .ts,.tsx --fix",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev:ui": "npm run dev -w @swarmhq/ui",
    "ui": "npm run build && node packages/cli/dist/bin.js ui",
    "ui:no-open": "npm run build && node packages/cli/dist/bin.js ui --no-open"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
